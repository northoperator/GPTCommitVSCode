{
  "name": "gpt-commit",
  "displayName": "GPT Commit",
  "description": "VS Code extension which helps to generate AI commit messages using ChatGPT",
  "version": "1.0.5",
  "homepage": "https://github.com/dmytrobaida/GPTCommitVSCode#readme",
  "bugs": "https://github.com/dmytrobaida/GPTCommitVSCode/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmytrobaida/GPTCommitVSCode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.76.0"
  },
  "publisher": "DmytroBaida",
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "Commit",
    "AI",
    "ChatGPT",
    "GPT",
    "git",
    "repository"
  ],
  "icon": "assets/images/icon256.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gptcommit.generateAICommit",
        "title": "Generate AI commit",
        "icon": {
          "dark": "assets/icons/commit-dark.svg",
          "light": "assets/icons/commit-light.svg"
        }
      },
      {
        "command": "gptcommit.setOpenAIApiKey",
        "title": "Set OpenAI API key"
      },
      {
        "command": "gptcommit.setGroqApiKey",
        "title": "Set Groq API key"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "gptcommit.generateAICommit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "GPT Commit",
      "properties": {
        "gptcommit.appearance.delimeter": {
          "type": "string",
          "default": "",
          "description": "Optional prefix added to each generated commit line"
        },
        "gptcommit.general.generator": {
          "type": "string",
          "enum": [
            "ChatGPT",
            "Groq"
          ],
          "default": "ChatGPT",
          "description": "Generator used to create commit messages"
        },
        "gptcommit.general.messageApproveMethod": {
          "type": "string",
          "enum": [
            "Quick pick",
            "Message file"
          ],
          "default": "Quick pick",
          "description": "How generated commit messages are handled. `Quick pick` inserts directly into the SCM input box, while `Message file` opens a temp file for review and editing."
        },
        "gptcommit.openAI.apiKey": {
          "type": "string",
          "default": "",
          "description": "Needed for generating AI commit messages"
        },
        "gptcommit.openAI.gptVersion": {
          "type": "string",
          "enum": [
            "gpt-4",
            "gpt-4-0613",
            "gpt-4-32k",
            "gpt-4-32k-0613",
            "gpt-3.5-turbo",
            "gpt-3.5-turbo-0613",
            "gpt-3.5-turbo-16k",
            "gpt-3.5-turbo-16k-0613"
          ],
          "default": "gpt-3.5-turbo-16k",
          "description": "Version of GPT used by OpenAI"
        },
        "gptcommit.openAI.customEndpoint": {
          "type": "string",
          "default": "",
          "description": "Custom endpoint URL for OpenAI API"
        },
        "gptcommit.openAI.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Controls randomness. Lowering results in less random completions. As the temperature approaches zero, the model will become deterministic and repetitive"
        },
        "gptcommit.openAI.maxTokens": {
          "type": "number",
          "default": 196,
          "description": "The maximum number of tokens to generate. Requests can use up to 2048 tokens shared between prompt and completion"
        },
        "gptcommit.groq.apiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key for generating AI commit messages"
        },
        "gptcommit.groq.model": {
          "type": "string",
          "default": "openai/gpt-oss-120b",
          "description": "Groq model to use for generating commit messages"
        },
        "gptcommit.groq.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Controls randomness. Lowering results in less random completions"
        },
        "gptcommit.groq.maxTokens": {
          "type": "number",
          "default": 196,
          "description": "The maximum number of tokens to generate"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run esbuild-base -- --sourcemap",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "package": "mkdir -p packages && vsce package -o packages/",
    "package:publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.76.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "execa": "^7.1.1",
    "groq-sdk": "^1.1.2",
    "openai": "^6.33.0",
    "zod": "^3.21.4"
  }
}
